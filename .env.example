# MongoDB connection string
DB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Prefijo de carpeta en S3 (opcional)
# Si está definido, el backup se guarda en: {S3_PREFIX}/backups/database/db-backup-YYYY-MM-DD.gz
# Si no está definido: backups/database/db-backup-YYYY-MM-DD.gz
S3_PREFIX=

# Días de retención de backups (default: 7)
RETENTION_DAYS=7
